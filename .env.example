# Database
DATABASE_URL=postgresql://user:password@localhost:5432/adminyzr

# Payload CMS
PAYLOAD_SECRET=your-super-secret-payload-key-change-in-production
NEXT_PUBLIC_APP_URL=http://localhost:3600

# Storage (S3-compatible — works with AWS S3 and Cloudflare R2)
#
# For Cloudflare R2:
#   S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
#   S3_REGION=auto
#   Get your Account ID from the Cloudflare dashboard > R2 > Overview.
#   Create an API token under R2 > Manage R2 API Tokens.
#
# For AWS S3:
#   S3_ENDPOINT=          (leave empty — the SDK uses the default AWS endpoint)
#   S3_REGION=eu-central-1
#
S3_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
S3_BUCKET=adminyzr-documents
S3_ACCESS_KEY_ID=your-access-key
S3_SECRET_ACCESS_KEY=your-secret-key
S3_REGION=auto

# Email (SMTP — Amazon SES of andere provider)
SMTP_HOST=email-smtp.eu-central-1.amazonaws.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
MAIL_FROM=noreply@adminyzr.com

# Monitoring (Sentry)
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# SENTRY_ORG=compass-digital
# SENTRY_PROJECT=adminyzr
# SENTRY_AUTH_TOKEN=

# Cron secret (voor betalingsherinneringen endpoint)
CRON_SECRET=your-cron-secret-key

# Sityzr integratie
# SITYZR_API_URL=https://api.sityzr.com
# SITYZR_API_KEY=
# SITYZR_WEBHOOK_SECRET=

# Stripe (abonnementenbeheer)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_ENTERPRISE=price_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Betaalproviders (Mollie/Stripe/MultiSafePay voor factuurbetalingen)
# API keys worden versleuteld opgeslagen in de database. Deze sleutel wordt
# gebruikt voor AES-256-GCM encryptie. Genereer met: openssl rand -hex 32
PAYMENT_KEY_ENCRYPTION_SECRET=
# Webhook URLs (configureer in provider dashboard):
#   Mollie:       https://your-domain/api/webhooks/payments/mollie
#   Stripe:       https://your-domain/api/webhooks/payments/stripe
#   MultiSafePay: https://your-domain/api/webhooks/payments/multisafepay

# OAuth2 SSO (optioneel)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=
# MICROSOFT_TENANT_ID=common

# OCR (Mindee API — factuurherkenning)
MINDEE_API_KEY=your-mindee-api-key

# Inbound email (AWS SES — inkoopfacturen via email)
# Tenants sturen facturen naar {slug}@INBOUND_EMAIL_DOMAIN
# SES ontvangt de mail en stuurt een SNS notificatie naar /api/webhooks/email
INBOUND_EMAIL_DOMAIN=inbox.adminyzr.com

# Redis (voor BullMQ job queue)
REDIS_URL=redis://localhost:6379
